# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase project values
# Get these from: Firebase Console → Project Settings → Your Apps → Web App → SDK setup

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here

# UPI Payment
NEXT_PUBLIC_UPI_ID=yourname@upi
NEXT_PUBLIC_UPI_NAME=Your Restaurant Name

# ── Role & Access ──────────────────────────────────────────────────────────────
# 4-digit PIN to protect the Billing role (change before going live!)
NEXT_PUBLIC_BILLING_PIN=1234

# ── Branding ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BUSINESS_NAME=Your Restaurant Name
NEXT_PUBLIC_RECEIPT_FOOTER=Thank you for dining with us!
# Leave blank if no GST registration
NEXT_PUBLIC_GST_NUMBER=
